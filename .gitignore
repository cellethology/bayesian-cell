# Ignore OS-generated files
.DS_Store
Thumbs.db

# Ignore dependency directories
node_modules/
venv/
__pycache__/
*.pyc
*.pyo
*.pyd

# Ignore build and package directories
build/
dist/
*.egg-info/
*.egg

# Ignore IDE/editor files
.vscode/
.idea/
*.sublime-workspace

# Ignore log files and temp files
logs/
*.log
*.out
*.tmp
_result/

# Ignore compiled binaries
*.o
*.obj
*.so
*.dll
*.exe

# Ignore environment files
.env
*.env
.env.local

# Ignore version control files
.git/
.gitignore

# Ignore Jupyter Notebook checkpoints
.ipynb_checkpoints/

# Ignore data files
*.csv
*.tsv
*.json
*.xml

# Ignore large media files
*.mp4
*.avi
*.mkv
*.mp3
*.wav
*.flac

# Ignore archive files
*.zip
*.tar
*.gz
*.bz2
*.rar
